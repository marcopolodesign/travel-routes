{
  "functions": {
    "api/payment-request.tsx": { "includeFiles": ["api/fonts/**", "api/package.json"] },
    "api/factura.tsx": { "includeFiles": ["api/fonts/**", "api/package.json"] }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!.*\\.[^/]*$).*)", "destination": "/index.html" }
  ]
}
